<mvc:View xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:f="sap.ui.layout.form"
             xmlns:core="sap.ui.core"
             xmlns:l="sap.ui.layout"
             controllerName="ey.ap.acc.controller.Add">

    <Page title="Manage Product" showNavButton="true" navButtonPress="onBack">
        <!-- <Button text="Back" icon="sap-icon://arrow-left" press="onBack"></Button> -->
        <VBox class="sapUiSmallMargin">
            <f:SimpleForm id="SimpleFormChange354"
                editable="true"
                layout="ResponsiveGridLayout"
                title="Product Details"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="3"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="4"
                emptySpanL="4"
                emptySpanM="4"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false" >
                <f:content>
                    <Label text="Product ID" />
                    <Input id="idProd" 
                    placeholder="Type product id and press enter to update.."
                    value="{zkas>/prodData/PRODUCT_ID}" submit="onSubmit"/>
                    <Button icon="sap-icon://iphone" tooltip="load most expensive product" press="onLoadExp"></Button>
                    <Label text="Name/Description" />
                    <Input value="{zkas>/prodData/NAME}">
                    </Input>
                    <Input value="{zkas>/prodData/DESCRIPTION}">
                        <layoutData>
                            <l:GridData span="XL1 L2 M2 S4" />
                        </layoutData>
                    </Input>
                    
                    <Label text="Supplier ID" />
                    <Input value="{zkas>/prodData/SUPPLIER_ID}" showValueHelp="true" valueHelpRequest="onF4Help">
                        <layoutData>
                            <l:GridData span="XL1 L2 M2 S4" />
                        </layoutData>
                    </Input>
                    <Text text="{zkas>/prodData/SUPPLIER_NAME}" />

                    <Label text="Price/Currency" />
                    <Input value="{zkas>/prodData/PRICE}" type="Number">
                        <layoutData>
                            <l:GridData span="XL1 L2 M2 S4" />
                        </layoutData>
                    </Input>
                    <Input value="{zkas>/prodData/CURRENCY_CODE}" />

                    <Label text="Category" />
                    <Select id="category" selectedKey="{zkas>/prodData/CATEGORY}">
                        <items>
                            <core:Item text="Notebooks" key="Notebooks"/>
                            <core:Item text="Projectors" key="Projectors"/>
                            <core:Item text="Mice" key="Mice"/>
                        </items>
                    </Select>
                </f:content>
            </f:SimpleForm>
        </VBox>

        <Image id="idphoto" width="60%" height="60%" />
        <footer>
            <Toolbar>
                <ToolbarSpacer ></ToolbarSpacer>
                <Button id="idSave" text="Save" type="Accept" press="onSave" icon="sap-icon://save"></Button>
                <Button id="idDelete" text="Delete" type="Reject" press="onDelete" icon="sap-icon://delete"></Button>
                <Button text="Clear" type="Emphasized" press="onClear" icon="sap-icon://cancel"></Button>
            </Toolbar>
        </footer>
    </Page>

</mvc:View>