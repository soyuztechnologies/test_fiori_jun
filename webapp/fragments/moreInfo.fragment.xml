<core:FragmentDefinition xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" 
             xmlns:f="sap.ui.layout.form"
             xmlns:core="sap.ui.core">
    <f:SimpleForm>
        <f:content>
            <Label text="Name"></Label>
            <Text text="{PRODUCT_ID} {NAME}"></Text>
            <Label text="Category"></Label>
            <Text text="{CATEGORY}"></Text>
            <Label text="UoM"></Label>
            <Text text="{DIM_UNIT}"></Text>
            <Label text="Cost"></Label>
            <Text text="{PRICE} {CURRENCY_CODE}"></Text>
        </f:content>
    </f:SimpleForm>

    <f:SimpleForm title="Supplier Info">
        <f:content>
            <Label text="Name"></Label>
            <Text text="{To_Supplier/COMPANY_NAME}"></Text>
            <Label text="Supplier Id"></Label>
            <Text text="{To_Supplier/BP_ID}"></Text>
            <Label text="contact"></Label>
            <Text text="{To_Supplier/EMAIL_ADDRESS}"></Text>
            <Label text="Location"></Label>
            <Text text="{To_Supplier/CITY} {To_Supplier/COUNTRY}"></Text>
        </f:content>
    </f:SimpleForm>
</core:FragmentDefinition>